# droply relay — environment variables
# Copy to .env for local dev (never commit .env to git)

# REQUIRED in production
RELAY_SECRET=change-this-to-64-random-hex-chars

# Redis connection (required in production, optional in --dev mode)
# Free options: Upstash (upstash.com), Render Redis, Railway Redis
REDIS_URL=redis://localhost:6379/0

# Optional tuning
SESSION_TTL_SEC=7200        # how long sessions live (seconds) — default 2h
CHUNK_SIZE_BYTES=2097152    # upload chunk size — default 2MB
MAX_FILE_SIZE=5368709120    # hard cap per file — default 5GB
MAX_FILES=20                # max files per session — default 20
PORT=6000                   # server port — default 6000
